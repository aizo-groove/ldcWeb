---
import Layout from "../layouts/Layout.astro";

const VERSION = "0.5.0";
const GITHUB = "https://github.com/aizo-groove/ldc";
const KOFI = "https://ko-fi.com/aizogroove";
const DL_MAC_ARM = `https://github.com/aizo-groove/ldc/releases/download/v${VERSION}/LDC_${VERSION}_aarch64.dmg`;
const DL_MAC_INTEL = `https://github.com/aizo-groove/ldc/releases/download/v${VERSION}/LDC_${VERSION}_x64.dmg`;
const DL_WIN = `https://github.com/aizo-groove/ldc/releases/download/v${VERSION}/LDC_${VERSION}_x64-setup.exe`;

const features = [
  { icon: "🧾", title: "Vente & tickets", desc: "Catalogue produits, panier, reçus thermiques via imprimante réseau." },
  { icon: "🗺️", title: "Plan de salle", desc: "Gestion des tables, commandes par table, transfert de table." },
  { icon: "🔒", title: "Conformité NF525", desc: "Journal d'audit, archive exportable, attestation PDF. Obligatoire en France." },
  { icon: "👥", title: "Multi-caissiers", desc: "Profils avec PIN, rôles gérant / caissier, session de caisse." },
  { icon: "🖥️", title: "Écran client", desc: "Affichage du panier en temps réel sur un second moniteur." },
  { icon: "🔄", title: "Mise à jour auto", desc: "Nouvelles versions livrées silencieusement, sans action de votre part." },
];

const profiles = [
  { icon: "🍽️", label: "Restaurant" },
  { icon: "☕", label: "Café / Bar" },
  { icon: "🥖", label: "Boulangerie" },
  { icon: "🛒", label: "Épicerie" },
  { icon: "🚚", label: "Food truck" },
];

// GitHub stats fetched at build time
let ghStars = 0;
let ghDownloads = 0;
let ghReleases = 0;
try {
  const [repoRes, releasesRes] = await Promise.all([
    fetch("https://api.github.com/repos/aizo-groove/ldc", {
      headers: { Accept: "application/vnd.github.v3+json" },
    }),
    fetch("https://api.github.com/repos/aizo-groove/ldc/releases?per_page=100", {
      headers: { Accept: "application/vnd.github.v3+json" },
    }),
  ]);
  const repo = await repoRes.json();
  const releases: any[] = await releasesRes.json();
  ghStars = repo.stargazers_count ?? 0;
  ghReleases = releases.length ?? 0;
  ghDownloads = releases.reduce(
    (sum, r) => sum + (r.assets ?? []).reduce((s: number, a: any) => s + (a.download_count ?? 0), 0),
    0
  );
} catch {}

const fmt = (n: number) => new Intl.NumberFormat("fr-FR").format(n);

const competitors = [
  { name: "Lightspeed",   price: 150 },
  { name: "Zelty",        price: 79  },
  { name: "Innovorder",   price: 99  },
  { name: "Addition",     price: 69  },
];

const kofiTiers = [
  { emoji: "🤷", label: "Prix conscient",  amount: "0 €",  desc: "Tu utilises, c'est déjà formidable. Vraiment." },
  { emoji: "☕", label: "Prix café",       amount: "3 €",  desc: "Les croquettes de Mimi le chat. Il mange cher." },
  { emoji: "🔧", label: "Prix outil",      amount: "10 €", desc: "Une licence de dev tool. Je vous vois, JetBrains." },
  { emoji: "🖥️", label: "Prix matériel",   amount: "30 €", desc: "Du hardware de test pour que LDC tourne partout." },
  { emoji: "🚀", label: "Prix militant",   amount: "50 €", desc: "Un mois d'abo concurrent économisé, réinvesti ici." },
];

// TODO: remplacer par de vrais témoignages (Ko-fi, retours directs, GitHub Discussions)
const testimonials = [
  {
    initials: "??",
    name: "Prénom N.",
    role: "Restaurateur",
    quote: "Votre témoignage ici — contactez-nous sur Ko-fi ou GitHub.",
  },
  {
    initials: "??",
    name: "Prénom N.",
    role: "Gérant de café",
    quote: "Votre témoignage ici — contactez-nous sur Ko-fi ou GitHub.",
  },
  {
    initials: "??",
    name: "Prénom N.",
    role: "Boulanger",
    quote: "Votre témoignage ici — contactez-nous sur Ko-fi ou GitHub.",
  },
];

const roadmapDone = [
  "Assistant d'onboarding en 5 étapes",
  "Visite guidée interactive de l'application",
  "Plan de salle & gestion des tables",
  "Écran client sur second moniteur",
  "Conformité NF525 — archive & attestation PDF",
  "Multi-caissiers avec PIN et rôles",
  "Gestion des appareils (imprimante, tiroir-caisse, scanner…)",
  "Mise à jour automatique silencieuse",
  "Notes de version à l'ouverture",
];

const roadmapNext = [
  { label: "Retours utilisateurs → GitHub Issues", desc: "Vos signalements arrivent directement aux développeurs." },
];

const roadmapPlanned = [
  { id: "tablets", icon: "📱", label: "Tablettes Android & iPad", desc: "Prise de commande en salle sur tablette." },
  { id: "linux",   icon: "🐧", label: "Linux (Raspberry Pi)",     desc: "Pour les kits hardware clé en main." },
  { id: "kds",     icon: "🍽️", label: "Affichage cuisine (KDS)",  desc: "Écran en cuisine, commandes en temps réel." },
  { id: "cloud",   icon: "☁️", label: "Sauvegarde cloud",          desc: "Vos données synchronisées et sécurisées." },
  { id: "multipos",icon: "🖧", label: "Multi-postes",              desc: "Plusieurs caisses sur le même réseau." },
];
---

<Layout>
  <!-- Nav -->
  <header class="fixed top-0 inset-x-0 z-50 border-b border-white/5 bg-zinc-950/80 backdrop-blur-md">
    <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
      <span class="font-black text-lg tracking-tight">LDC</span>
      <nav class="flex items-center gap-6 text-sm text-zinc-400">
        <a href="#fonctionnalites" class="hover:text-white transition-colors">Fonctionnalités</a>
        <a href="#roadmap" class="hover:text-white transition-colors">Roadmap</a>
        <a href="#tarifs" class="hover:text-white transition-colors">Tarifs</a>
        <a href={GITHUB} target="_blank" class="hover:text-white transition-colors">GitHub</a>
        <a href={KOFI} target="_blank" class="px-3 py-1.5 bg-orange-500 text-white text-xs font-bold rounded-lg hover:opacity-90 transition-opacity">
          Soutenir ☕
        </a>
      </nav>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section class="pt-32 pb-16 px-6 max-w-6xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 items-center">

        <!-- Texte -->
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-orange-500/10 border border-orange-500/20 text-orange-400 text-xs font-semibold mb-8">
            ✦ Open source · Gratuit · Conforme NF525
          </div>

          <h1 class="text-5xl sm:text-6xl font-black tracking-tight leading-tight mb-6">
            Un logiciel de caisse<br />
            <span class="text-orange-500">ne devrait pas coûter</span><br />
            2 400 € par an.
          </h1>

          <p class="text-zinc-400 text-lg leading-relaxed mb-10 max-w-xl">
            LDC est un logiciel de caisse libre, conforme NF525, sans abonnement.
            Pour les restaurants, cafés et commerces indépendants qui refusent de payer
            pour ce qui devrait être un droit.
          </p>

          <div class="flex flex-wrap gap-3">
            <a href={DL_MAC_ARM} class="flex items-center gap-2 px-5 py-3 bg-white text-zinc-900 font-bold text-sm rounded-xl hover:bg-zinc-100 transition-colors">
              🍎 macOS Apple Silicon
            </a>
            <a href={DL_MAC_INTEL} class="flex items-center gap-2 px-5 py-3 bg-white/10 text-white font-bold text-sm rounded-xl hover:bg-white/15 transition-colors border border-white/10">
              🍎 macOS Intel
            </a>
            <a href={DL_WIN} class="flex items-center gap-2 px-5 py-3 bg-white/10 text-white font-bold text-sm rounded-xl hover:bg-white/15 transition-colors border border-white/10">
              🪟 Windows
            </a>
          </div>
          <p class="text-zinc-600 text-xs mt-5">v{VERSION} · macOS & Windows · Mise à jour automatique</p>
        </div>

        <!-- Screenshot -->
        <div class="relative">
          <!-- Halo orange derrière la fenêtre -->
          <div class="absolute inset-0 bg-orange-500/10 blur-3xl rounded-3xl"></div>
          <!-- Fenêtre macOS fictive -->
          <div class="relative rounded-2xl overflow-hidden border border-white/10 shadow-2xl">
            <!-- Barre de titre -->
            <div class="flex items-center gap-1.5 px-4 py-3 bg-zinc-800 border-b border-white/5">
              <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
              <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
              <span class="ml-3 text-xs text-zinc-500 font-medium">LDC — Logiciel de Caisse</span>
            </div>
            <!-- Screenshot -->
            <img
              src="/screenshot.png"
              alt="Interface de LDC — logiciel de caisse"
              class="w-full block"
              width="800"
              height="500"
            />
          </div>
        </div>

      </div>
    </section>

    <!-- Stats -->
    <section class="border-y border-white/5 bg-white/[0.02] py-12 px-6">
      <div class="max-w-4xl mx-auto grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-8 text-center">
        <div>
          <p class="text-3xl font-black text-white">0 €</p>
          <p class="text-zinc-500 text-sm mt-1">par mois pour toujours</p>
        </div>
        <div>
          <p class="text-3xl font-black text-orange-500">NF525</p>
          <p class="text-zinc-500 text-sm mt-1">conformité légale incluse</p>
        </div>
        <div class="col-span-2 sm:col-span-1">
          <p class="text-3xl font-black text-white">100%</p>
          <p class="text-zinc-500 text-sm mt-1">open source</p>
        </div>
        <div>
          <p class="text-3xl font-black text-white">{ghDownloads > 0 ? fmt(ghDownloads) : "—"}</p>
          <p class="text-zinc-500 text-sm mt-1">téléchargements</p>
        </div>
        <div>
          <p class="text-3xl font-black text-white">{ghReleases > 0 ? fmt(ghReleases) : "—"}</p>
          <p class="text-zinc-500 text-sm mt-1">versions publiées</p>
        </div>
      </div>
    </section>

    <!-- Pour qui -->
    <section class="py-20 px-6 max-w-5xl mx-auto">
      <h2 class="text-2xl font-black text-center mb-12 uppercase tracking-tight">Fait pour vous si vous êtes…</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
        {profiles.map((item) => (
          <div class="flex flex-col items-center gap-3 p-5 rounded-2xl bg-white/5 border border-white/5 hover:border-white/10 transition-colors">
            <span class="text-3xl">{item.icon}</span>
            <span class="text-sm font-semibold">{item.label}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Fonctionnalités -->
    <section id="fonctionnalites" class="py-20 px-6 bg-white/[0.02] border-y border-white/5">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-2xl font-black text-center mb-12 uppercase tracking-tight">Ce que vous obtenez</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {features.map((f) => (
            <div class="p-6 rounded-2xl bg-zinc-900 border border-white/5">
              <span class="text-2xl">{f.icon}</span>
              <h3 class="font-bold mt-3 mb-1">{f.title}</h3>
              <p class="text-zinc-500 text-sm leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Tarifs -->
    <section id="tarifs" class="py-20 px-6 bg-white/[0.02] border-y border-white/5">
      <div class="max-w-4xl mx-auto">

        <!-- Accroche -->
        <h2 class="text-2xl font-black text-center mb-3 uppercase tracking-tight">Combien ça coûte ?</h2>
        <p class="text-center text-zinc-500 mb-14 text-sm">
          LDC est gratuit. Voici ce que vous évitez de payer ailleurs.
        </p>

        <!-- Comparatif concurrents -->
        <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-3 mb-6">
          {competitors.map((c) => (
            <div class="p-4 rounded-2xl bg-zinc-900 border border-white/5 text-center">
              <p class="text-zinc-500 text-xs font-semibold mb-2">{c.name}</p>
              <p class="text-xl font-black text-red-400">{c.price} €<span class="text-xs font-normal text-zinc-600">/mois</span></p>
              <p class="text-zinc-700 text-xs mt-1">{c.price * 12} € /an</p>
            </div>
          ))}
          <div class="p-4 rounded-2xl bg-orange-500/10 border border-orange-500/30 text-center">
            <p class="text-orange-400 text-xs font-semibold mb-2">LDC</p>
            <p class="text-xl font-black text-white">0 €<span class="text-xs font-normal text-zinc-500">/mois</span></p>
            <p class="text-orange-500/60 text-xs mt-1">pour toujours</p>
          </div>
        </div>

        <p class="text-center text-zinc-600 text-xs mb-16">
          Économie moyenne : <span class="text-white font-bold">1 000 à 1 800 € par an</span> selon le concurrent.
        </p>

        <!-- Ko-fi tiers -->
        <h3 class="text-lg font-black text-center mb-2 uppercase tracking-tight">Soutenir le projet</h3>
        <p class="text-center text-zinc-500 text-sm mb-10">
          Aucune obligation. Si LDC vous aide, un geste est toujours bienvenu.
        </p>

        <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-3">
          {kofiTiers.map((tier, i) => (
            <a
              href={KOFI}
              target="_blank"
              class={`group p-5 rounded-2xl border flex flex-col gap-3 transition-all hover:-translate-y-0.5 ${
                i === 4
                  ? "bg-orange-500/10 border-orange-500/30 hover:border-orange-500/60"
                  : "bg-zinc-900 border-white/5 hover:border-white/15"
              }`}
            >
              <span class="text-2xl">{tier.emoji}</span>
              <div>
                <p class={`font-black text-lg ${i === 4 ? "text-orange-400" : "text-white"}`}>{tier.amount}</p>
                <p class="text-xs font-semibold text-zinc-400">{tier.label}</p>
              </div>
              <p class="text-zinc-600 text-xs leading-relaxed">{tier.desc}</p>
            </a>
          ))}
        </div>

      </div>
    </section>

    <!-- Témoignages -->
    <section class="py-20 px-6 max-w-5xl mx-auto">
      <h2 class="text-2xl font-black text-center mb-3 uppercase tracking-tight">Ils utilisent LDC</h2>
      <p class="text-center text-zinc-500 mb-12 text-sm">
        Un retour à partager ?
        <a href={KOFI} target="_blank" class="text-orange-400 hover:text-orange-300 transition-colors">Ko-fi</a>
        ou
        <a href={GITHUB + "/discussions"} target="_blank" class="text-orange-400 hover:text-orange-300 transition-colors">GitHub Discussions</a>.
      </p>
      <div class="grid sm:grid-cols-3 gap-6">
        {testimonials.map((t) => (
          <div class="p-6 rounded-2xl bg-zinc-900 border border-white/5 flex flex-col gap-4">
            <p class="text-zinc-400 text-sm leading-relaxed flex-1">"{t.quote}"</p>
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full bg-orange-500/20 border border-orange-500/30 flex items-center justify-center text-orange-400 text-xs font-black shrink-0">
                {t.initials}
              </div>
              <div>
                <p class="text-sm font-semibold leading-tight">{t.name}</p>
                <p class="text-zinc-600 text-xs">{t.role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Roadmap -->
    <section id="roadmap" class="py-20 px-6 max-w-5xl mx-auto">
      <h2 class="text-2xl font-black text-center mb-3 uppercase tracking-tight">Feuille de route</h2>
      <p class="text-center text-zinc-500 mb-14 text-sm">Le projet est actif — voici où on en est et où on va.</p>

      <div class="grid lg:grid-cols-3 gap-8">

        <!-- Fait -->
        <div>
          <div class="flex items-center gap-2 mb-5">
            <span class="text-green-400 text-lg">✅</span>
            <h3 class="font-black uppercase tracking-tight text-sm">Déjà disponible</h3>
          </div>
          <ul class="space-y-2.5">
            {roadmapDone.map((item) => (
              <li class="flex items-start gap-2.5 text-sm text-zinc-400">
                <span class="text-green-400 mt-0.5 shrink-0">✓</span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Prochaine version -->
        <div>
          <div class="flex items-center gap-2 mb-5">
            <span class="text-orange-400 text-lg">🔜</span>
            <h3 class="font-black uppercase tracking-tight text-sm">Version suivante</h3>
          </div>
          <div class="space-y-4">
            {roadmapNext.map((item) => (
              <div class="p-4 rounded-xl bg-orange-500/10 border border-orange-500/20">
                <p class="font-semibold text-sm text-orange-300">{item.label}</p>
                <p class="text-zinc-500 text-xs mt-1">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- En préparation + votes -->
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="text-zinc-400 text-lg">💡</span>
            <h3 class="font-black uppercase tracking-tight text-sm">En préparation</h3>
          </div>
          <p class="text-zinc-600 text-xs mb-5">Votez pour prioriser ce qui compte le plus pour vous.</p>
          <div class="space-y-3">
            {roadmapPlanned.map((item) => (
              <div class="flex items-center gap-3 p-4 rounded-xl bg-white/[0.03] border border-white/5 hover:border-white/10 transition-colors">
                <button
                  data-vote-id={item.id}
                  class="vote-btn shrink-0 flex flex-col items-center gap-0.5 w-10 px-2 py-1.5 rounded-lg bg-white/5 hover:bg-orange-500/20 hover:text-orange-400 transition-all text-zinc-500 border border-white/5 hover:border-orange-500/30"
                  aria-label={`Voter pour ${item.label}`}
                >
                  <span class="text-xs leading-none">▲</span>
                  <span class="vote-count text-xs font-bold leading-none" data-id={item.id}>—</span>
                </button>
                <div class="min-w-0">
                  <p class="font-semibold text-sm">{item.icon} {item.label}</p>
                  <p class="text-zinc-500 text-xs mt-0.5">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>

      <p class="text-center text-zinc-600 text-xs mt-12">
        Roadmap complète sur <a href={GITHUB + "/blob/main/docs/ROADMAP.md"} target="_blank" class="hover:text-zinc-400 transition-colors underline underline-offset-2">GitHub</a>
      </p>
    </section>

    <!-- Ko-fi -->
    <section class="py-20 px-6 border-t border-white/5 text-center">
      <div class="max-w-xl mx-auto">
        <p class="text-4xl mb-6">🐱</p>
        <h2 class="text-2xl font-black mb-4 uppercase tracking-tight">Un projet indépendant</h2>
        <p class="text-zinc-400 leading-relaxed mb-8">
          LDC est développé par une seule personne, en dehors des heures de boulot.
          Le code est public, la feuille de route est ouverte.
          Si ça vous aide, un café est toujours bienvenu.
        </p>
        <div class="flex items-center justify-center gap-4">
          <a href={KOFI} target="_blank" class="px-5 py-3 bg-orange-500 text-white font-bold text-sm rounded-xl hover:opacity-90 transition-opacity">
            Offrir un café ☕
          </a>
          <a href={GITHUB} target="_blank" class="px-5 py-3 bg-white/10 text-white font-bold text-sm rounded-xl hover:bg-white/15 transition-colors border border-white/10">
            Voir le code
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-white/5 py-8 px-6 text-center text-zinc-600 text-sm">
    <p>LDC v{VERSION} · Open source · <a href={GITHUB} class="hover:text-zinc-400 transition-colors">GitHub</a> · <a href={KOFI} class="hover:text-zinc-400 transition-colors">Ko-fi</a></p>
  </footer>

<script>
  const API = "/api/votes";
  const STORAGE_KEY = "ldc_votes";

  function getVoted(): Set<string> {
    try {
      return new Set(JSON.parse(localStorage.getItem(STORAGE_KEY) ?? "[]"));
    } catch {
      return new Set();
    }
  }

  function saveVoted(voted: Set<string>) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify([...voted]));
  }

  function applyVotedStyle(btn: HTMLButtonElement) {
    btn.classList.add("!bg-orange-500/20", "!text-orange-400", "!border-orange-500/30");
    btn.disabled = true;
  }

  async function loadCounts() {
    try {
      const res = await fetch(API);
      if (!res.ok) return;
      const data: Record<string, number> = await res.json();
      document.querySelectorAll<HTMLElement>(".vote-count").forEach((el) => {
        const id = el.dataset.id!;
        el.textContent = String(data[id] ?? 0);
      });
    } catch {}
  }

  document.addEventListener("DOMContentLoaded", async () => {
    await loadCounts();

    const voted = getVoted();
    document.querySelectorAll<HTMLButtonElement>(".vote-btn").forEach((btn) => {
      const id = btn.dataset.voteId!;
      if (voted.has(id)) applyVotedStyle(btn);

      btn.addEventListener("click", async () => {
        if (voted.has(id)) return;
        voted.add(id);
        saveVoted(voted);
        applyVotedStyle(btn);

        const countEl = btn.querySelector<HTMLElement>(".vote-count")!;
        countEl.textContent = String((parseInt(countEl.textContent ?? "0") || 0) + 1);

        try {
          const res = await fetch(API, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ id }),
          });
          if (res.ok) {
            const { count } = await res.json();
            countEl.textContent = String(count);
          }
        } catch {}
      });
    });
  });
</script>
</Layout>
